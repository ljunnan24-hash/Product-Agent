{
  "name": "taste-agent",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3020",
    "local": "node scripts/local-runner.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "audit:evidence-bindings": "node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/audit-report-evidence-bindings.mjs",
    "intake:calibrate": "node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/audit-material-intake.mjs",
    "worker:drain": "node scripts/drain-worker-queue.mjs",
    "worker:local-drain": "node scripts/local-worker-drain.mjs",
    "worker:launchd": "node scripts/manage-worker-launchd.mjs",
    "doctor": "node scripts/local-doctor.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "typescript": "^5.7.2"
  }
}
